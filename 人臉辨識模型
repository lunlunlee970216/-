import os  
import cv2                                                                 #import cv2是匯入opencv這個影像工具箱

# 載入人臉偵測模型
face_cascade = cv2.CascadeClassifier(
        cv2.data.haarcascades + "haarcascade_frontalface_default.xml"                                     
                           )                                                                                   
if face_cascade.empty():                                                  #如果模型是空的就印出錯誤訊息
    print("模型載入失敗！")
else:
    print("模型載入成功！")                                                                                                        

cap = cv2.VideoCapture(0)                                                 #cv2.VideoCapture(0)開啟電腦的第一個攝像機，cap是代表攝像機的意思(有點像變數?)


while True:
    ret, frame = cap.read()                                               #cap.read()是讀攝影機影像，cap剛好用到剛剛設定的變數，frame是一禎的畫面
    if not ret:                                                           #ret是return value回傳變數的意思
        break  
        
                            
    # 轉成灰階（人臉偵測比較準）
    gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)                        #cv2.cvtColor是顏色轉換函數，cv2.COLOR_BGR2GRAY把彩色圖轉成灰色
                                    
                                    
    # 偵測人臉
    faces = face_cascade.detectMultiScale(                                #detectMultiScale是在不同大小的比例下，偵測很多不同的臉
        gray,                                                   
        scaleFactor=1.375,                                                #每次縮小 1.375倍再找，越小範圍就可以找得越精準
        minNeighbors=2                                                    #至少要2個判定是臉才能算臉
    )

    # 把人臉框起來
    for (x, y, w, h) in faces:                                            #回傳每個臉的(x,y,w,h)的座標
        cv2.rectangle(                                                    #cv2.rectangle在影像中的臉上畫矩形
            frame,                  
            (x, y),                                                       #左上角的座標   
            (x + w, y + h),                                               #右下角的座標       
            (0, 500, 0),                                                  #矩形綠色框
            3                                                             #矩形線寬
        )

    # 顯示畫面
    cv2.imshow("Face Detection", frame)                                   #cv2.imshow顯示視窗，Face Detection視窗標題，frame當前畫面

    # 按 q 離開
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break
                                                                          #按q結束畫面
cap.release()
cv2.destroyAllWindows()
